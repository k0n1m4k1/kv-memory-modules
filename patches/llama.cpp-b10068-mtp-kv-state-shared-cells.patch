+bool llama_kv_cache::state_read_meta_shared(llama_io_read_i & io, uint32_t strm, uint32_t cell_count, slot_info & sinfo, llama_seq_id dest_seq_id) {
+    const auto & cells = v_cells[strm];
+
+    sinfo.s0 = strm;
+    sinfo.s1 = strm;
+    sinfo.resize(1);
+    sinfo.strm[0] = strm;
+    sinfo.idxs[0].resize(cell_count);
+
+    // single-sequence restores go through find_slot() in the source cache, so the
+    // cell indices are not known here - index the shared cells by position
+    std::unordered_map<llama_pos, uint32_t> pos_to_idx;
+    if (dest_seq_id != -1) {
+        for (uint32_t i = 0; i < cells.size(); ++i) {
+            if (!cells.is_empty(i) && cells.seq_has(i, dest_seq_id)) {
+                pos_to_idx[cells.pos_get(i)] = i;
+            }
+        }
+    }
+
+    for (uint32_t i = 0; i < cell_count; ++i) {
+        llama_pos pos;
+        uint32_t  n_seq_id;
+
+        io.read(&pos,      sizeof(pos));
+        io.read(&n_seq_id, sizeof(n_seq_id));
+
+        if (hparams.n_pos_per_embd() > 1) {
+            llama_kv_cell_ext ext;
+            io.read(&ext, sizeof(ext));
+        }
+
+        for (uint32_t j = 0; j < n_seq_id; ++j) {
+            llama_seq_id seq_id;
+            io.read(&seq_id, sizeof(seq_id));
+        }
+
+        if (dest_seq_id != -1) {
+            const auto it = pos_to_idx.find(pos);
+            if (it == pos_to_idx.end()) {
+                LLAMA_LOG_ERROR("%s: pos %d not found in the shared cells - restore the source cache first\n", __func__, pos);
+                return false;
+            }
+            sinfo.idxs[0][i] = it->second;
+        } else {
+            // whole-cache restores place the cells at [0, cell_count) in blob order,
+            // and both caches are saved from the same shared cells in the same order
+            if (i >= cells.size() || cells.is_empty(i) || cells.pos_get(i) != pos) {
+                LLAMA_LOG_ERROR("%s: shared cell %u does not match pos %d - restore the source cache first\n", __func__, i, pos);
+                return false;
+            }
+            sinfo.idxs[0][i] = i;
+        }
+    }
+
+    return true;
+}
